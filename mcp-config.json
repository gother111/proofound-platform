{
  "mcpServers": {
    "FigmaMCP": {
      "url": "http://127.0.0.1:3845/mcp"
    },
    "supabase-mcp-server": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=cjpfrgmsxwxhuomnvciq"
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"]
    },
    "vercel": {
      "command": "npx",
      "args": ["-y", "@robinson_ai_systems/vercel-mcp"]
    },
    "postgres": {
      "command": "node",
      "args": ["scripts/mcp-postgres.mjs"]
    },
    "github-actions": {
      "command": "npx",
      "args": ["-y", "@nextdrive/github-action-trigger-mcp"]
    }
  }
}
