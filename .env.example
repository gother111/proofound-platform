# App Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional fallback used by select legacy helpers. Keep in sync with NEXT_PUBLIC_SITE_URL when set.
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_ENV=local

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_USE_MOCK_SUPABASE=false
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
DATABASE_URL=
DIRECT_URL=
PII_HASH_SALT=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=
# Optional comma-separated admin recipients for LinkedIn manual-review notifications.
# Falls back to PLATFORM_ADMIN_EMAILS when unset.
LINKEDIN_VERIFICATION_ADMIN_EMAILS=

# Cron Jobs
# Generate with: openssl rand -base64 32
CRON_SECRET=
# Dedicated signing key for browser CSRF tokens.
# Generate with: openssl rand -base64 32
CSRF_SECRET=
# Optional cron-job.org API token for syncing external worker jobs from this repo.
CRON_API_KEY=
# Optional dedicated secret for internal API-to-API calls.
# If omitted, CRON_SECRET is used as fallback.
INTERNAL_API_SECRET=
# Optional dedicated secret for the internal Python document-intelligence service.
# Falls back to PYTHON_INTERNAL_SERVICE_SECRET -> CV_IMPORT_PROXY_INTERNAL_SECRET -> INTERNAL_API_SECRET -> CRON_SECRET.
PYTHON_INTERNAL_SERVICE_SECRET=

# Optional debug ingest sink (disabled by default)
DEBUG_INGEST_ENABLED=false
DEBUG_INGEST_URL=
NEXT_PUBLIC_DEBUG_INGEST_URL=

# Provider OAuth (target-scoped; manual meeting links remain the default launch path)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Deterministic strict provider E2E user (only when connected-provider scheduling is target-blocking)
E2E_PROVIDER_USER_ID=
E2E_PROVIDER_USER_EMAIL=
E2E_PROVIDER_USER_PASSWORD=
STRICT_PROVIDER_E2E_REQUIRE_CONNECTED=false

# Feature Flags (optional)
# Matching is enabled by default. Uncomment only as an emergency kill switch.
# MATCHING_FEATURE_ENABLED=false
NEXT_PUBLIC_WIREFRAME_MODE=false
# Explicit local visual fixture mode. Keep both flags false outside local visual QA.
PROOFOUND_VISUAL_FIXTURES=false
NEXT_PUBLIC_PROOFOUND_VISUAL_FIXTURES=false

# Legacy CV Import (archived/non-launch; not part of controlled AI/OCR rollout)
CV_IMPORT_ENGINE_MODE=auto
CV_IMPORT_FORCE_PYTHON=false
PYTHON_CV_IMPORT_BASE_URL=
CV_IMPORT_SEMANTIC_ENABLED=true
CV_IMPORT_SERVER_TIMEOUT_MS=15000
CV_IMPORT_WIZARD_TIMEOUT_MS=45000
CV_IMPORT_USER_RATE_LIMIT_MAX=12
CV_IMPORT_USER_RATE_LIMIT_WINDOW_SECONDS=60
CV_IMPORT_MAX_DOCUMENTS=5
CV_IMPORT_MAX_CHARS_PER_DOCUMENT=30000
CV_IMPORT_MAX_TOTAL_CHARS=90000
CV_IMPORT_MAX_FILE_SIZE_MB=5
CV_IMPORT_MAX_PDF_PAGES=4
# Legacy fallback. Prefer PYTHON_INTERNAL_SERVICE_SECRET for new deployments.
CV_IMPORT_PROXY_INTERNAL_SECRET=
MATCHING_REFRESH_QUEUE_ENABLED=true
MATCHING_REFRESH_WORKER_BATCH_SIZE=100
MATCHING_REFRESH_WORKER_CONCURRENCY=4
MATCHING_REFRESH_MAX_ATTEMPTS=3
PYTHON_INTERNAL_JOBS_ENABLED=true
PYTHON_INTERNAL_WORKER_BATCH_SIZE=10
PYTHON_INTERNAL_WORKER_CONCURRENCY=2
PYTHON_INTERNAL_WORKER_LEASE_SECONDS=180
PYTHON_INTERNAL_MAX_ATTEMPTS=3
# Assistive AI UI is default-on through FF_ASSISTIVE_AI_UI. Server model calls still require
# AI_ASSISTANTS_ENABLED=true, a server-only Gemini key, and budget/rate caps; when absent,
# proof-improve and assignment-clarify return deterministic manual fallback guidance.
AI_ASSISTANTS_ENABLED=false
AI_MODEL_DEFAULT=gemini-3.1-flash-lite
AI_MODEL_FALLBACK=
AI_MODEL_FALLBACK_VERIFIED=false
AI_PROVIDER_SMOKE_LAST_SUCCESS_AT=
AI_PROVIDER_SMOKE_ARTIFACT_PATH=.artifacts/ai-provider-smoke.json
AI_GEMINI_PROD_API_KEY=
AI_GEMINI_STAGING_API_KEY=
AI_MONTHLY_HARD_CAP_SEK=500
AI_PROD_MONTHLY_HARD_CAP_SEK=500
AI_GLOBAL_DAILY_LIMIT=250
AI_USER_DAILY_LIMIT=20
AI_ORG_DAILY_LIMIT=50
AI_PROOF_PACK_ASSISTANT_DAILY_LIMIT=500
AI_ASSIGNMENT_CLARITY_DAILY_LIMIT=500
AI_VERIFICATION_REQUEST_COMPOSER_DAILY_LIMIT=500
AI_PRIVACY_PREFLIGHT_DAILY_LIMIT=500
AI_RAW_PROMPT_LOGGING_ENABLED=false
CV_IMPORT_GEMINI_PRIMARY_MONTHLY_BUDGET_SEK=80
CV_IMPORT_GEMINI_SECONDARY_MONTHLY_BUDGET_SEK=80
CV_IMPORT_GEMINI_USD_TO_SEK_RATE=10.5
CV_IMPORT_GEMINI_MODEL_DEFAULT=gemini-3.1-flash-lite
CV_IMPORT_GEMINI_MODEL_FALLBACK=
CV_IMPORT_GEMINI_MAX_OUTPUT_TOKENS=1600
CV_IMPORT_GEMINI_SHORT_TEXT_MAX_OUTPUT_TOKENS=1000
CV_IMPORT_GEMINI_TEMPERATURE=0
CV_IMPORT_GEMINI_TIMEOUT_MS=12000
CV_IMPORT_GEMINI_TAXONOMY_GUIDED=false
CV_IMPORT_GEMINI_SHORTLIST_MAX_ENTRIES=120
CV_IMPORT_GEMINI_SHORTLIST_MAX_TOKENS=1200
CV_IMPORT_GEMINI_SHORTLIST_SEED_LIMIT=8
CV_IMPORT_GEMINI_SHORTLIST_CONCURRENCY=4
CV_IMPORT_GEMINI_SHORTLIST_QUERY_TIMEOUT_MS=1500
CV_IMPORT_GEMINI_SHORTLIST_DOCUMENT_TIMEOUT_MS=8000
CV_IMPORT_GEMINI_SHORTLIST_CACHE_TTL_MS=600000
CV_IMPORT_GEMINI_TAXONOMY_VERSION=v1
CV_IMPORT_GEMINI_FLASH_LITE_INPUT_USD_PER_MILLION=0.25
CV_IMPORT_GEMINI_FLASH_LITE_OUTPUT_USD_PER_MILLION=1.5
CV_IMPORT_GEMINI_FLASH_INPUT_USD_PER_MILLION=0.3
CV_IMPORT_GEMINI_FLASH_OUTPUT_USD_PER_MILLION=2.5
NEXT_PUBLIC_CV_IMPORT_REVIEW_V3=true
NEXT_PUBLIC_CV_IMPORT_OCR_ENABLED=false
NEXT_PUBLIC_CV_IMPORT_OCR_MAX_FILE_SIZE_MB=5
NEXT_PUBLIC_CV_IMPORT_OCR_MAX_PAGES=4
NEXT_PUBLIC_CV_IMPORT_OCR_PAGE_TIMEOUT_MS=8000
NEXT_PUBLIC_CV_IMPORT_OCR_TIMEOUT_MS=25000
NEXT_PUBLIC_CV_IMPORT_OCR_RENDER_SCALE=2
NEXT_PUBLIC_CV_IMPORT_OCR_LANGUAGE=eng
# Temporary server-side GCP Document AI Proof Artifact OCR beta config.
# Disabled by default; do not commit real secrets. Not CV import.
PROOF_ARTIFACT_OCR_BETA_ENABLED=false

# Authenticated-individual Start from CV. This is a private draft-onboarding helper,
# not CV screening, matching, ranking, verification, or employer-side parsing.
START_FROM_CV_BETA_ENABLED=false
START_FROM_CV_GUEST_FIRST_PROOF_SCAFFOLDING_ENABLED=false
# Legacy allow-list variables are retained for rollback/compatibility only; they no longer gate
# access once the feature and approved private scaffolding gates are enabled.
START_FROM_CV_ALLOWED_USER_IDS=
START_FROM_CV_ALLOWED_ORG_IDS=
START_FROM_CV_USE_GCP_OCR=false
START_FROM_CV_USE_GEMINI_STRUCTURING=false
START_FROM_CV_AI_PROVIDER=gemini
START_FROM_CV_DEEPSEEK_API_KEY=
START_FROM_CV_DEEPSEEK_BASE_URL=https://api.deepseek.com
START_FROM_CV_DEEPSEEK_MODEL=deepseek-v4-flash
START_FROM_CV_DEEPSEEK_PERSONAL_DATA_ENABLED=false
START_FROM_CV_DEEPSEEK_PRODUCTION_ENABLED=false
START_FROM_CV_MAX_FILE_SIZE_MB=5
START_FROM_CV_MAX_PAGES=4
START_FROM_CV_USER_DAILY_LIMIT=3
START_FROM_CV_GLOBAL_DAILY_LIMIT=20
START_FROM_CV_RETENTION_HOURS=24
START_FROM_CV_DELETE_SOURCE_AFTER_EXTRACTION=true
PROOF_ARTIFACT_OCR_BETA_KILL_SWITCH=false
GCP_CV_OCR_ENABLED=false
GCP_CV_OCR_KILL_SWITCH=false
# Required only when temporarily enabling. Review on 2026-07-15, drill disabled mode
# on 2026-07-25, decide disable-or-paid by 2026-08-01, credits expire 2026-08-03.
GCP_CV_OCR_EXPIRES_AT=2026-08-01T00:00:00Z
GCP_CV_OCR_EMERGENCY_DISABLE_HOURS=72
# Required only when temporarily enabling. Must be a trusted https service origin.
GCP_CV_OCR_BASE_URL=
# Supported values: oidc or hmac. Production should use oidc; hmac is for short local/staging smoke only.
GCP_CV_OCR_AUTH_MODE=oidc
# Server-only HMAC shared secret for short smoke windows. Leave empty for OIDC.
GCP_CV_OCR_SHARED_SECRET=
GCP_CV_OCR_OIDC_AUDIENCE=
GCP_CV_OCR_OIDC_PROJECT_NUMBER=
GCP_CV_OCR_OIDC_WORKLOAD_IDENTITY_POOL_ID=
GCP_CV_OCR_OIDC_WORKLOAD_IDENTITY_PROVIDER_ID=
GCP_CV_OCR_OIDC_SERVICE_ACCOUNT_EMAIL=
GCP_CV_OCR_MAX_FILE_SIZE_MB=5
GCP_CV_OCR_MAX_PAGES=4
GCP_CV_OCR_MAX_FILES_PER_REQUEST=1
GCP_CV_OCR_ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png
GCP_CV_OCR_RETENTION_HOURS=24
GCP_CV_OCR_USER_DAILY_LIMIT=5
GCP_CV_OCR_GLOBAL_DAILY_LIMIT=20
GCP_CV_OCR_HARD_BUDGET_CAP_SEK=
GCP_CV_OCR_BUDGET_CAP_EXHAUSTED=false
GCP_CV_OCR_BUDGET_ALERT_CONFIGURED=false
GCP_CV_OCR_CLOUD_RUN_MAX_INSTANCES=1
GCP_CV_OCR_CLOUD_RUN_MAX_INSTANCES_DOCUMENTED=false
GCP_CV_OCR_CLOUD_RUN_PUBLIC_INVOCATION=false
# Cloud Run service-only values for the temporary Document AI provider. This path uses
# the Cloud Run service account / ADC, not Google API keys or browser-created Gemini keys.
GCP_CV_OCR_PROVIDER=document_ai
GCP_CV_OCR_PROJECT_ID=
GCP_CV_OCR_DOCUMENT_AI_LOCATION=
GCP_CV_OCR_DOCUMENT_AI_PROCESSOR_ID=
AI_GLOBAL_KILL_SWITCH=false
AI_KILL_SWITCH_PROOF_PACK_ASSISTANT=false
AI_KILL_SWITCH_ASSIGNMENT_CLARITY=false
AI_KILL_SWITCH_VERIFICATION_COMPOSER=false
AI_KILL_SWITCH_PRIVACY_PREFLIGHT=false

# Rate Limiting
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=30

# Error Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DEBUG=false

# Caching (Vercel KV / Redis)
# These are automatically set by Vercel when you add KV storage
# For local development, leave empty to use in-memory cache
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
