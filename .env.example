# App Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=local

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=

# Cron Jobs
# Generate with: openssl rand -base64 32
CRON_SECRET=
# Optional dedicated secret for internal API-to-API calls.
# If omitted, CRON_SECRET is used as fallback.
INTERNAL_API_SECRET=

# Feature Flags (optional)
MATCHING_FEATURE_ENABLED=true
NEXT_PUBLIC_WIREFRAME_MODE=false

# Rate Limiting
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=30

# Error Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DEBUG=false

# Caching (Vercel KV / Redis)
# These are automatically set by Vercel when you add KV storage
# For local development, leave empty to use in-memory cache
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
