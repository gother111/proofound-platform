# App Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional fallback used by select legacy helpers. Keep in sync with NEXT_PUBLIC_SITE_URL when set.
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_ENV=local

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
PII_HASH_SALT=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=

# Cron Jobs
# Generate with: openssl rand -base64 32
CRON_SECRET=
# Optional dedicated secret for internal API-to-API calls.
# If omitted, CRON_SECRET is used as fallback.
INTERNAL_API_SECRET=

# Optional debug ingest sink (disabled by default)
DEBUG_INGEST_ENABLED=false
DEBUG_INGEST_URL=
NEXT_PUBLIC_DEBUG_INGEST_URL=

# Provider OAuth (MVP strict)
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Deterministic strict provider E2E user (must have Zoom + Google connected)
E2E_PROVIDER_USER_ID=
E2E_PROVIDER_USER_EMAIL=
E2E_PROVIDER_USER_PASSWORD=
STRICT_PROVIDER_E2E_REQUIRE_CONNECTED=true
STRICT_PROVIDER_E2E_REQUIRE_BOTH=true

# Feature Flags (optional)
MATCHING_FEATURE_ENABLED=true
NEXT_PUBLIC_WIREFRAME_MODE=false

# Rate Limiting
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=30

# Error Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DEBUG=false

# Caching (Vercel KV / Redis)
# These are automatically set by Vercel when you add KV storage
# For local development, leave empty to use in-memory cache
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
