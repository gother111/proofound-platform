{
  "functions": {
    "api/python/cv_import.py": {
      "maxDuration": 60,
      "includeFiles": "python_cv/data/skills_db.json",
      "excludeFiles": "{src/**,scripts/**,supabase/**,emails/**,tests/**,e2e/**,docs/**,project/**,agent/**}"
    }
  },
  "crons": [
    {
      "path": "/api/cron/account-deletion-workflow",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/refresh-matches",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/refresh-matches-worker",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/cron/decision-reminders",
      "schedule": "0 10 * * *"
    }
  ]
}
