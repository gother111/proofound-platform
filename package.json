{
  "type": "module",
  "engines": {
    "node": ">=20.20.0 <21"
  },
  "scripts": {
    "prebuild": "node ./scripts/check-deploy-readiness.mjs",
    "dev": "node ./scripts/next-dev-node20.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "node ./scripts/lint-or-skip.js",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "typecheck": "tsc --noEmit --incremental false",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node run-migrations.mjs",
    "db:drift-check": "node ./scripts/check-migration-drift.mjs",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed-taxonomy": "tsx scripts/seed-expertise-taxonomy.ts",
    "db:backup:checkpoint": "node ./scripts/db-backup-checkpoint.mjs",
    "db:audit:migrations": "node ./scripts/audit-migration-ledger.mjs",
    "email:dev": "email dev --dir src/emails",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node ./scripts/playwright-node20.mjs test",
    "test:e2e:ui": "node ./scripts/playwright-node20.mjs test --ui",
    "test:e2e:landing": "node ./scripts/playwright-node20.mjs test e2e/landing-page.spec.ts --project=chromium --reporter=line",
    "test:e2e:landing:visual": "node ./scripts/playwright-node20.mjs test e2e/landing-visual.spec.ts --project=chromium --reporter=line",
    "test:e2e:auth": "npm run test:e2e:auth:mock",
    "test:e2e:auth:mock": "CI=1 NEXT_PUBLIC_USE_MOCK_SUPABASE=true node ./scripts/playwright-node20.mjs test e2e/auth.spec.ts --project=chromium --reporter=line",
    "test:e2e:auth:real": "NEXT_PUBLIC_USE_MOCK_SUPABASE=false node ./scripts/playwright-node20.mjs test e2e/auth.real.spec.ts --project=chromium --reporter=line --workers=1",
    "test:e2e:mobile": "NEXT_PUBLIC_USE_MOCK_SUPABASE=true MOCK_ORG_MODE=true MOCK_ADMIN_MODE=true PLAYWRIGHT=true node ./scripts/playwright-node20.mjs test e2e/mobile-smartphone.spec.ts --project=chromium --workers=1 --reporter=line",
    "test:e2e:individual:strict": "NEXT_PUBLIC_USE_MOCK_SUPABASE=false node ./scripts/playwright-node20.mjs test e2e/strict/individual.strict.spec.ts --project=chromium --reporter=line --workers=1",
    "test:e2e:org:strict": "NEXT_PUBLIC_USE_MOCK_SUPABASE=false node ./scripts/playwright-node20.mjs test e2e/strict/organization.strict.spec.ts --project=chromium --reporter=line --workers=1",
    "test:e2e:privacy:strict": "NEXT_PUBLIC_USE_MOCK_SUPABASE=false node ./scripts/playwright-node20.mjs test e2e/strict/privacy.strict.spec.ts --project=chromium --reporter=line --workers=1",
    "test:e2e:providers:strict": "STRICT_PROVIDER_E2E_REQUIRE_CONNECTED=${STRICT_PROVIDER_E2E_REQUIRE_CONNECTED:-true} STRICT_PROVIDER_E2E_REQUIRE_BOTH=${STRICT_PROVIDER_E2E_REQUIRE_BOTH:-true} NEXT_PUBLIC_USE_MOCK_SUPABASE=false node ./scripts/playwright-node20.mjs test e2e/strict/providers.strict.spec.ts --project=chromium --reporter=line --workers=1",
    "test:e2e:strict:all": "npm run test:strict:quality && npm run test:e2e:individual:strict && npm run test:e2e:org:strict && npm run test:e2e:privacy:strict && npm run test:e2e:providers:strict",
    "test:a11y": "node ./scripts/playwright-node20.mjs test --config playwright.a11y.config.ts --project=chromium",
    "test:a11y:strict": "NEXT_PUBLIC_USE_MOCK_SUPABASE=false node ./scripts/playwright-node20.mjs test --config playwright.a11y.strict.config.ts --project=chromium",
    "test:strict:quality": "node ./scripts/check-strict-e2e-quality.mjs",
    "test:privacy": "vitest run --config vitest.supabase.config.ts tests/privacy/rls-policies.test.ts",
    "test:privacy:all": "vitest run --config vitest.supabase.config.ts tests/privacy",
    "test:privacy:watch": "vitest watch --config vitest.supabase.config.ts tests/privacy",
    "test:privacy:coverage": "vitest run --coverage --config vitest.supabase.config.ts tests/privacy",
    "test:privacy:extended": "vitest run --config vitest.supabase.config.ts tests/privacy/rls-policies-extended.test.ts",
    "seed:prd-supabase": "tsx scripts/seed-prd-flows.ts",
    "prepare": "husky install",
    "perf:budgets": "node ./scripts/perf-budgets.mjs",
    "go:no-go": "node ./scripts/go-no-go-check.mjs",
    "gates:mvp:strict": "node ./scripts/run-mvp-strict-gates.mjs",
    "vercel:preflight": "node ./scripts/vercel-preflight.mjs",
    "vercel:env-parity": "node ./scripts/vercel-env-parity.mjs",
    "docs:freshness": "node ./scripts/docs-freshness-check.mjs",
    "log:session": "node ./scripts/new-session-log.mjs session",
    "log:change": "node ./scripts/new-session-log.mjs change",
    "test:smoke:gap-service": "tsx scripts/smoke-skill-gaps.ts",
    "test:smoke:learning": "tsx scripts/smoke-learning-provider.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.3.4",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^0.5.7",
    "@sentry/nextjs": "^10.27.0",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.39.7",
    "@tanstack/react-query": "^5.24.1",
    "@vercel/analytics": "^1.5.0",
    "@vercel/kv": "^3.0.0",
    "@vercel/speed-insights": "^1.2.0",
    "@xenova/transformers": "^2.17.2",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "^1.1.1",
    "compromise": "^14.14.4",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.29.4",
    "framer-motion": "^11.0.5",
    "googleapis": "^144.0.0",
    "gsap": "^3.13.0",
    "lenis": "^1.3.15",
    "lucide-react": "^0.344.0",
    "nanoid": "^5.0.5",
    "next": "^15.5.12",
    "next-intl": "^3.9.0",
    "next-themes": "^0.2.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.16.3",
    "postgres": "^3.4.3",
    "react": "^18.2.0",
    "react-day-picker": "^9.11.1",
    "react-dom": "^18.2.0",
    "react-email": "^4.3.2",
    "react-hook-form": "^7.50.1",
    "react-joyride": "^3.0.0-7",
    "react-markdown": "^10.1.0",
    "recharts": "^2.12.7",
    "remark-gfm": "^4.0.1",
    "resend": "^3.5.0",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "web-vitals": "^5.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.8.5",
    "@playwright/test": "^1.41.2",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.4",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.0.1",
    "drizzle-kit": "^0.31.8",
    "eslint": "^8",
    "eslint-config-next": "^15.5.12",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "husky": "^9.0.11",
    "jsdom": "^24.0.0",
    "lighthouse": "^12.0.0",
    "lint-staged": "^15.2.2",
    "postcss": "^8",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.3.0",
    "tsx": "^4.7.1",
    "typescript": "^5",
    "vitest": "^1.3.1"
  },
  "overrides": {
    "@sentry/nextjs": "^10.27.0",
    "@sentry/node": "^10.27.0",
    "@sentry/node-core": "^10.27.0",
    "esbuild": "^0.27.1",
    "glob": "^11.1.0",
    "js-yaml": "^4.1.1",
    "jws": "^4.0.1",
    "mdast-util-to-hast": "^13.2.1",
    "vite": "^7.2.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
